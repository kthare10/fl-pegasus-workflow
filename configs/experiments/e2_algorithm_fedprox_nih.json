{
  "experiment_id": "E2",
  "experiment_name": "algorithm_fedprox_nih",
  "notes": "Planned FedProx config. Current code still behaves as FedAvg until train_client.py implements FedProx.",
  "requires_code_changes": ["fedprox_local_objective"],
  "dataset_name": "nih-cxr14",
  "task": "multi_label_classification",
  "data_root": "/path/to/ChestX-ray14/images",
  "metadata_files": ["/path/to/Data_Entry_2017_v2020.csv"],
  "sample_id_column": "Image Index",
  "patient_id_column": "Patient ID",
  "label_column": "Finding Labels",
  "allow_synthetic_fallback": false,
  "container_image": "docker://kthare10/fl-medical-imaging:latest",
  "client_partition_strategy": "patient_label_skew",
  "num_clients": 10,
  "samples_per_client": 0,
  "split_seed": 13,
  "train_fraction": 0.7,
  "val_fraction": 0.1,
  "model_name": "linear-smoke",
  "feature_dim": 16,
  "image_size": 224,
  "batch_size": 32,
  "learning_rate": 0.05,
  "rounds": 50,
  "local_epochs": 5,
  "aggregation": "fedprox",
  "prox_mu": 0.01,
  "request_gpus": 0,
  "labels": [
    "Atelectasis",
    "Cardiomegaly",
    "Consolidation",
    "Edema",
    "Effusion",
    "Emphysema",
    "Fibrosis",
    "Hernia",
    "Infiltration",
    "Mass",
    "Nodule",
    "Pleural_Thickening",
    "Pneumonia",
    "Pneumothorax",
    "No Finding"
  ],
  "evaluation_metrics": ["macro_auroc", "micro_auroc", "client_accuracy"]
}
