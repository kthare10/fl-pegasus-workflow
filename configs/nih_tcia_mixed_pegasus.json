{
  "dataset_name": "nih-tcia-mixed",
  "task": "binary_mixed_medical_imaging",
  "allow_synthetic_fallback": false,
  "container_image": "docker://kthare10/fl-medical-imaging:latest",
  "stage_input_data": true,
  "split_seed": 17,
  "train_fraction": 0.7,
  "val_fraction": 0.1,
  "model_name": "linear-smoke",
  "feature_dim": 24,
  "image_size": 96,
  "batch_size": 16,
  "learning_rate": 0.03,
  "rounds": 50,
  "local_epochs": 5,
  "aggregation": "fedavg",
  "request_gpus": 0,
  "positive_terms": ["nodule", "positive", "malignant", "pneumonia", "effusion", "mass"],
  "labels": [
    "Atelectasis",
    "Cardiomegaly",
    "Consolidation",
    "Edema",
    "Effusion",
    "Emphysema",
    "Fibrosis",
    "Hernia",
    "Infiltration",
    "Mass",
    "Nodule",
    "Pleural_Thickening",
    "Pneumonia",
    "Pneumothorax",
    "No Finding"
  ],
  "evaluation_metrics": ["accuracy", "client_accuracy"],
  "dataset_pipelines": [
    {
      "name": "tcia",
      "dataset_name": "tcia-mixed-collections",
      "task": "collection_proxy_binary_classification",
      "data_root": "/home/ubuntu/fl-pegasus-workflow/tcia",
      "metadata_files": [],
      "auto_discover_images": true,
      "patient_id_from": "filename_stem",
      "label_from_top_level_dir": false,
      "directory_label_map": {
        "LIDC-IDRI": "nodule",
        "NSCLC-Radiogenomics": "malignant",
        "NSCLC-Radiomics": "malignant",
        "RIDER-Lung-CT": "benign",
        "TCGA-LUAD": "malignant"
      },
      "default_label": "unknown",
      "client_partition_strategy": "top_level_directory",
      "num_clients": 10,
      "samples_per_client": 0
    },
    {
      "name": "nih",
      "dataset_name": "nih-cxr14",
      "task": "multi_label_classification",
      "data_root": "/path/to/ChestX-ray14/images",
      "metadata_files": ["/path/to/Data_Entry_2017_v2020.csv"],
      "sample_id_column": "Image Index",
      "patient_id_column": "Patient ID",
      "label_column": "Finding Labels",
      "client_partition_strategy": "patient_label_skew",
      "num_clients": 10,
      "samples_per_client": 0
    }
  ]
}
